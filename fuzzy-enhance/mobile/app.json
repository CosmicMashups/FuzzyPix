{
  "expo": {
    "name": "FuzzyEnhance",
    "slug": "fuzzy-enhance",
    "version": "1.0.0",
    "scheme": "fuzzy-enhance",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FuzzyEnhance to access your photos.",
          "cameraPermission": "Allow FuzzyEnhance to use the camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
